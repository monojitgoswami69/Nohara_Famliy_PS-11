# Backend API URL
# During LOCAL development, leave this EMPTY — Vite's dev proxy handles routing
# to the backend automatically (see vite.config.ts proxy config).
# For production, set this to your deployed backend URL (origin only):
# VITE_API_URL=https://api.codecollab.noharafamily.xyz
# If /api is included, it is also supported.
VITE_API_URL=

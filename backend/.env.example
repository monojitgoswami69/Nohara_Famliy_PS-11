# GitHub OAuth App credentials
# Create one at: https://github.com/settings/applications/new
GITHUB_CLIENT_ID=your_client_id_here
GITHUB_CLIENT_SECRET=your_client_secret_here
GITHUB_OAUTH_SCOPES="repo read:org read:user"

# Frontend app origin (used for OAuth popup postMessage target)
# Dev example:  http://localhost:3000
# Prod example: https://codecollab.noharafamily.xyz
FRONTEND_URL=http://localhost:3000

# Optional comma-separated CORS origins. If omitted, FRONTEND_URL is used.
# FRONTEND_ORIGINS=http://localhost:3000,https://codecollab.noharafamily.xyz

# Public backend URL used for GitHub OAuth redirect_uri.
# Leave empty in local dev (callback stays on FRONTEND_URL + /api through dev proxy).
# Set in production, e.g. https://api.codecollab.noharafamily.xyz
BACKEND_PUBLIC_URL=
